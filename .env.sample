# 服务端口（默认 3000）
PORT=3000

# OMDb API Key（用于获取 IMDb 评分，请替换为你自己的 Key）
# 注册地址：http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=1234567890

# 豆瓣 API Key（用于获取中文元数据，请替换为你自己的 Key）
DOUBAN_API_KEY=1234567890
DOUBAN_API_KEY2=1234567890

# TMDB API Key（选填，增强海报和元数据来源）
TMDB_API_KEY=1234567890

# 数据库路径（默认 ./data/movies.db）
DB_PATH=./data/movies.db

# 海报缓存目录（默认 ./data/images）
POSTER_DIR=./data/images
